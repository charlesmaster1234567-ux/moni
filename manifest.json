{
  "name": "ChatHub - Real-time Chat Application",
  "short_name": "ChatHub",
  "description": "Connect. Chat. Collaborate in real-time.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f0f1a",
  "theme_color": "#6366f1",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "any",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  
  "categories": [
    "social",
    "communication"
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Open Chat",
      "short_name": "Chat",
      "description": "Open main chat",
      "url": "/",
      "icons": [{ "src": "/icons/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "video/*", "audio/*"]
        }
      ]
    }
  }
}